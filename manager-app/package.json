{
  "name": "aipilot-manager",
  "version": "0.1.0",
  "private": true,
  "description": "AIPilot Manager desktop app",
  "author": "NGCoding",
  "main": "main.js",
  "scripts": {
    "app": "electron .",
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never"
  },
  "build": {
    "appId": "tn.aipilot.manager",
    "productName": "AIPilot Manager",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "category": "Development",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
